

# ── Banco de dados (usado internamente pelo docker-compose) ───────────────────
DB_USER=finanalytics
DB_PASSWORD=troque_para_uma_senha_forte_aqui
DB_NAME=finanalytics


# ── Primeiro acesso — admin do cliente ────────────────────────────────────────
# Criado automaticamente na primeira inicialização. Troque a senha após entrar.
CLIENT_ADMIN_EMAIL=admin@suaempresa.com
CLIENT_ADMIN_PASSWORD=troque_esta_senha_no_primeiro_acesso

# ── Sessão ────────────────────────────────────────────────────────────────────
# Gere com: openssl rand -base64 48
SESSION_SECRET=

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Obtenha em: https://console.anthropic.com
# O cliente é responsável pelos custos de uso diretamente com a Anthropic.
ANTHROPIC_API_KEY=sk-ant-...

# ── Porta exposta pelo container ───────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Langfuse — observabilidade de IA (opcional) ───────────────────────────────
LANGFUSE_ENABLED=false
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
# LANGFUSE_MASK_LEVEL=basic

# ── Email (convites e recuperação de senha) ───────────────────────────────────
SMTP_USER=
SMTP_PASS=

# ── CORS ──────────────────────────────────────────────────────────────────────
# URL pública do sistema (com https://)
FRONTEND_URL=https://app.seudominio.com

