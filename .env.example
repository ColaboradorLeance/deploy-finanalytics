# ── Banco de dados ────────────────────────────────────────────────────────────
# Formato: postgresql://usuario:senha@host:porta/banco
# Exemplo: postgresql://finanalytics:senha123@seu-banco.host.com:5432/finanalytics
DATABASE_URL=postgresql://usuario:senha@host:5432/banco

# ── Primeiro acesso — admin do cliente ────────────────────────────────────────
# Criado automaticamente na primeira inicialização. Troque a senha após entrar.
CLIENT_ADMIN_EMAIL=admin@suaempresa.com
CLIENT_ADMIN_PASSWORD=troque_esta_senha_no_primeiro_acesso

# ── Sessão ────────────────────────────────────────────────────────────────────
# Gere com: openssl rand -base64 48
SESSION_SECRET=

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Obtenha em: https://console.anthropic.com
# O cliente é responsável pelos custos de uso diretamente com a Anthropic.
ANTHROPIC_API_KEY=sk-ant-...

# ── Ambiente ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# Cookies de sessão — controla o atributo Secure do cookie
# true (padrão): exige HTTPS — use em produção com proxy SSL na frente
# false: funciona em HTTP — use APENAS para testes locais sem SSL
# SECURE_COOKIES=false

# ── Documentação da API ────────────────────────────────────────────────────────
# Habilita /api/docs (Swagger UI) mesmo em produção.
# DOCS_ENABLED=true

# ── Langfuse — observabilidade de IA (opcional) ───────────────────────────────
LANGFUSE_ENABLED=false
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
# LANGFUSE_MASK_LEVEL=basic

# ── Email (convites e recuperação de senha) ───────────────────────────────────
SMTP_USER=
SMTP_PASS=

# ── CORS ──────────────────────────────────────────────────────────────────────
# URL pública do sistema (com https://)
FRONTEND_URL=https://app.seudominio.com

# ── API setorial (fornecida pela Finanalytics, se habilitada) ─────────────────
# BEDROCK_NEWS_API_URL=

